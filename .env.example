# ── Backend (apps/api/.env) ─────────────────────────────────────────────────────
# Copy this file to apps/api/.env and fill in real values before running

# Supabase (optional — app runs with in-memory fallback without these)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Auth
JWT_SECRET=generate-a-256-bit-random-secret-here
JWT_EXPIRY_DAYS=7

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_PRIMARY=gemini-3.5-flash
GEMINI_MODEL_FALLBACK=gemini-3.1-flash-lite
GEMINI_TIMEOUT_SECS=8

# CORS — comma-separated list
CORS_ORIGINS=["http://localhost:3000","https://your-frontend.run.app"]

# Demo account
DEMO_USER_EMAIL=demo@verdant.ai
DEMO_USER_PASSWORD=demo-verdant-2026

# ── Frontend (apps/web/.env.local) ──────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
